# ================================================
# AI Berkshire KR — .gitignore
# ================================================

# ────────────────────────────────────────
# 운영체제 자동 생성 파일
# ────────────────────────────────────────
.DS_Store           # macOS 폴더 메타데이터
Thumbs.db           # Windows 썸네일 캐시
desktop.ini         # Windows 폴더 설정

# ────────────────────────────────────────
# Python 캐시 및 빌드 산출물
# ────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# ────────────────────────────────────────
# 에디터 / IDE 설정 폴더
# ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ────────────────────────────────────────
# Claude Code / Codex 내부 파일
# ────────────────────────────────────────
.codex/
.claude/

# ────────────────────────────────────────
# 임시 파일
# ────────────────────────────────────────
/tmp/

# ────────────────────────────────────────
# 로그 파일 (명령어 기록, 개인정보 포함)
# ────────────────────────────────────────
logs/command-log.jsonl
logs/.counter

# ────────────────────────────────────────
# 대용량 미디어 파일
# 필요 시 git add -f 로 명시적 추가
# ────────────────────────────────────────
*.m4a
*.mp3
*.wav
*.mp4
*.mov
*.avi
*.mkv

# ────────────────────────────────────────
# 환경변수 / API 키 파일 (절대 공개 금지)
# ────────────────────────────────────────
.env
.env.local
.env.*.local

# ────────────────────────────────────────
# 한국 증권사 API 인증 토큰 캐시
# ────────────────────────────────────────
/tmp/kis_token.json        # 한국투자증권 KIS API 토큰
/tmp/kiwoom_token.json     # 키움증권 OpenAPI 토큰
/tmp/ebest_token.json      # 이베스트투자증권 토큰

# ────────────────────────────────────────
# 로컬 전용 자료 (공개하지 않을 파일)
# 이 폴더에 넣으면 Git이 영구적으로 무시
# ────────────────────────────────────────
/local/

# ────────────────────────────────────────
# 실제 포지션/수익 기록 (개인 자산 정보)
# ────────────────────────────────────────
reports/portfolio-latest.md
/실盘기록-원본/

# ────────────────────────────────────────
# 중간 과정 파일 (최종 리포트만 커밋)
# ────────────────────────────────────────
research/
*_data_collection.md
*_draft.md

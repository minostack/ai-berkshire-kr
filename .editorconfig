root = true

# ────────────────────────────────────────
# 모든 파일 공통 설정
# ────────────────────────────────────────
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# ────────────────────────────────────────
# Python 파일 (PEP8 표준: 스페이스 4칸)
# ────────────────────────────────────────
[*.py]
indent_style = space
indent_size = 4

# ────────────────────────────────────────
# 마크다운 리포트
# 줄 끝 공백 2칸 = 줄바꿈 문법이므로 제거하지 않음
# ────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false

# ────────────────────────────────────────
# JSON / YAML 설정 파일
# ────────────────────────────────────────
[*.{json,yaml,yml}]
indent_size = 2

# ────────────────────────────────────────
# 배치 파일 (Windows 스크립트)
# Windows에서 실행되므로 CRLF 사용
# ────────────────────────────────────────
[*.bat]
end_of_line = crlf
